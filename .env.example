# ============================================
#  XWarden — Configuration Template
# ============================================
#  1. Copy to .env:  cp .env.example .env
#  2. Fill in your values
#  3. Run:          python run.py
# ============================================

# ── Monitor Target ──────────────────────────

# X/Twitter username to monitor (without leading @)
XWARDEN_USER=aleabitoreddit
# Number of latest tweets to scan per run
XWARDEN_LIMIT=5

# ── Notification Channels (at least one) ───

# Telegram Bot
TG_BOT_TOKEN=
# Telegram chat / group ID
TG_CHAT_ID=

# Bark (iOS push)
BARK_KEY=

*** Feishu / Lark custom webhook
FEISHU_WEBHOOK=

# ── LLM Translation ─────────────────────────

# Enable: true / false
TRANSLATE_ENABLED=true
# Target language:
#   zh-CN  zh-TW  ja  ko  en  fr  de  ...
TRANSLATE_TARGET=zh-CN

# Translation backend: minimax / deepseek
TRANSLATE_MODEL=minimax

# MiniMax API (Token Plan)
MINIMAX_API_KEY=
***

# DeepSeek API (pay-as-you-go)
DEEPSEEK_API_KEY=
***
